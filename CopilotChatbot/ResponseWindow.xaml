<Window x:Class="CopilotChatbot.ResponseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Response" Height="760" Width="980" WindowStartupLocation="CenterOwner">
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushModern}" BorderThickness="0,0,0,1" Padding="16,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource ControlBrush}"
                            BorderBrush="{DynamicResource BorderBrushModern}"
                            BorderThickness="1"
                            CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="DocumentText20" Foreground="{DynamicResource AccentBrush}" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Response Viewer" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="Full content view" FontSize="11"
                                   Foreground="{DynamicResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Margin="0,0,8,0" Click="Copy_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Chr" Background="{DynamicResource ControlBrush}"
                                        BorderBrush="{DynamicResource BorderBrushModern}" BorderThickness="1" CornerRadius="8">
                                    <StackPanel Orientation="Horizontal" Margin="12,7">
                                        <ui:SymbolIcon Symbol="Copy20" FontSize="15" Foreground="{DynamicResource TextBrush}" Margin="0,0,6,0" />
                                        <TextBlock Text="Copy" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource TextBrush}" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Chr" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Click="Save_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Chr" Background="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="8">
                                    <StackPanel Orientation="Horizontal" Margin="12,7">
                                        <ui:SymbolIcon Symbol="Save20" FontSize="15" Foreground="White" Margin="0,0,6,0" />
                                        <TextBlock Text="Save" FontWeight="SemiBold" FontSize="13" Foreground="White" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Chr" Property="Background" Value="#0856B3" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Chr" Property="Background" Value="#0648A0" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <wv2:WebView2 x:Name="Browser" />
    </DockPanel>
</Window>
