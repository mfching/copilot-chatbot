<Window
    x:Class="CopilotChatbot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Copilot Chatbot"
    Icon="Assets/AppIcon.ico"
    Width="1280"
    Height="820"
    MinWidth="1080"
    MinHeight="720"
    Background="{DynamicResource PageBrush}"
    mc:Ignorable="d">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FAFBFC" />
        <SolidColorBrush x:Key="PageBrush" Color="#F3F5F8" />
        <SolidColorBrush x:Key="ControlBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushModern" Color="#D0D7DE" />
        <SolidColorBrush x:Key="TextBrush" Color="#1F2328" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5D6673" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0A65CC" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E7F1FF" />
        <SolidColorBrush x:Key="DisabledControlBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="DisabledBorderBrush" Color="#D1D5DB" />
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#8A94A3" />

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#B8C2CC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource DisabledControlBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Accent (blue) send button – keeps white text on all states  -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0856B3" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#0856B3" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0648A0" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#0648A0" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource DisabledControlBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="BorderBrush" Value="#DC2626" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#B91C1C" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#B91C1C" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#991B1B" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#991B1B" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource DisabledControlBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="CloseTabButton" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFECEE" />
                                <Setter Property="Foreground" Value="#B42318" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{DynamicResource TabStripColumnWidth}" MinWidth="216" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Padding="6,6,0,6"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,0,1"
                                CornerRadius="12,0,0,12">
                                <ScrollViewer
                                    CanContentScroll="False"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <TabPanel
                                        Panel.ZIndex="1"
                                        IsItemsHost="True"
                                        KeyboardNavigation.TabIndex="1" />
                                </ScrollViewer>
                            </Border>
                            <GridSplitter
                                Grid.Column="1"
                                Width="5"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Transparent"
                                Cursor="SizeWE"
                                DragCompleted="TabStripSplitter_DragCompleted"
                                DragDelta="TabStripSplitter_DragDelta" />
                            <Border
                                Grid.Column="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="0,12,12,0">
                                <ContentPresenter
                                    x:Name="PART_SelectedContentHost"
                                    ContentSource="SelectedContent"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Margin="0,0,-1,0">
                            <Border
                                x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,0,0,8">
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    ContentSource="Header"
                                    TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <Border
                                x:Name="AccentBar"
                                Width="3"
                                Margin="0,7,0,7"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="2"
                                Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
                                <Setter TargetName="AccentBar" Property="Opacity" Value="1" />
                                <Setter Property="BorderThickness" Value="1,1,0,1" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Primary (blue) toolbar button – used for New Chat  -->
        <Style x:Key="PrimaryToolbarButton" TargetType="Button">
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0856B3" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#0856B3" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0648A0" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Ghost icon-only button – used for Refresh / Theme / Settings  -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,1,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconToggleButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,1,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Clean TextBox style: no WPF-UI bottom accent bar  -->
        <Style x:Key="PromptTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Padding="{TemplateBinding Padding}"
                                Focusable="False"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#9BA4AE" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource DisabledControlBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border
            Padding="14,7"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushModern}"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Brand (left)  -->
                <StackPanel
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Grid
                        Width="34"
                        Height="34"
                        Margin="0,0,10,0">
                        <Border Background="#101828" CornerRadius="10" />
                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="23"
                            Foreground="#6CB6FF"
                            Symbol="BrainCircuit24" />
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextBrush}"
                            Text="Copilot Chatbot" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{DynamicResource MutedTextBrush}"
                            Text="AI-powered conversations" />
                    </StackPanel>
                </StackPanel>

                <!--  Model selectors (center, fills available space)  -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="3*" MinWidth="340" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource MutedTextBrush}"
                        Text="Model" />
                    <ComboBox
                        x:Name="ModelComboBox"
                        Grid.Column="1"
                        MinWidth="340"
                        Margin="0,0,8,0"
                        DisplayMemberPath="DisplayName"
                        SelectionChanged="ModelComboBox_SelectionChanged" />
                    <TextBlock
                        Grid.Column="2"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource MutedTextBrush}"
                        Text="Reasoning" />
                    <ComboBox
                        x:Name="ReasoningComboBox"
                        Grid.Column="3"
                        SelectionChanged="ReasoningComboBox_SelectionChanged" />
                </Grid>

                <!--  Action buttons (right)  -->
                <StackPanel
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="NewChatButton"
                        Click="NewChatButton_Click"
                        Style="{StaticResource PrimaryToolbarButton}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                Margin="0,0,7,0"
                                FontSize="17"
                                Symbol="AddCircle20" />
                            <TextBlock Text="New Chat" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="ClearChatButton"
                        Click="ClearChatButton_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Clear chat history">
                        <ui:SymbolIcon
                            FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                            Symbol="Delete20" />
                    </Button>
                    <Button
                        x:Name="SessionPromptButton"
                        Click="SessionPromptButton_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Edit session system prompt">
                        <ui:SymbolIcon
                            FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                            Symbol="NotepadPerson20" />
                    </Button>
                    <Button
                        x:Name="RefreshModelsButton"
                        Click="RefreshModelsButton_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Refresh models">
                        <ui:SymbolIcon
                            FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                            Symbol="ArrowClockwise20" />
                    </Button>
                    <Border
                        Width="1"
                        Margin="2,6,4,6"
                        Background="{DynamicResource BorderBrushModern}" />
                    <ToggleButton
                        x:Name="ShowDetailsCheckBox"
                        Click="ShowDetailsCheckBox_Click"
                        Style="{StaticResource IconToggleButton}"
                        ToolTip="Show reasoning, tool calls, and intent messages">
                        <ui:SymbolIcon
                            FontSize="18"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                            Symbol="TextBulletListSquare20" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="MemoryCheckBox"
                        Click="MemoryCheckBox_Click"
                        Style="{StaticResource IconToggleButton}"
                        ToolTip="Allow Copilot memory across sessions">
                        <ui:SymbolIcon
                            FontSize="18"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                            Symbol="BrainCircuit20" />
                    </ToggleButton>
                    <Border
                        Width="1"
                        Margin="0,6,4,6"
                        Background="{DynamicResource BorderBrushModern}" />
                    <Button
                        x:Name="ThemeButton"
                        Click="ThemeButton_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Theme: Light — click for Dark">
                        <ui:SymbolIcon
                            x:Name="ThemeIcon"
                            FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                            Symbol="WeatherMoon20" />
                    </Button>
                    <Button
                        x:Name="SessionInfoButton"
                        Click="SessionInfoButton_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Session capabilities (MCP servers, agents, skills)">
                        <ui:SymbolIcon
                            FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                            Symbol="PlugConnected20" />
                    </Button>
                    <Button
                        x:Name="SchedulerButton"
                        Click="SchedulerButton_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Scheduled tasks">
                        <ui:SymbolIcon
                            FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                            Symbol="CalendarClock24" />
                    </Button>
                    <Button
                        x:Name="SettingsButton"
                        Margin="0"
                        Click="SettingsButton_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Settings">
                        <ui:SymbolIcon
                            FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                            Symbol="Settings20" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar
            Padding="8,2"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushModern}"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="ConnectionStatusTextBlock" Text="Copilot: not connected" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="ModelStatusTextBlock" Text="Models: not refreshed" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="UsageStatusTextBlock" Text="Usage: waiting for assistant usage event" />
            </StatusBarItem>
        </StatusBar>

        <Grid Background="{DynamicResource PageBrush}">
            <TabControl
                x:Name="ChatTabs"
                Margin="6,8,6,8"
                SelectionChanged="ChatTabs_SelectionChanged"
                TabStripPlacement="Left" />
        </Grid>
    </DockPanel>
</Window>
