<Window x:Class="CopilotChatbot.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings" Height="700" Width="900" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PageBrush}">
    <Window.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chr" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chr" Property="Background" Value="#0856B3" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chr" Property="Background" Value="#0648A0" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chr" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chr" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Chr" Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chr" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource PanelBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Height" Value="30" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridColumnHeader">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="Transparent" Padding="2,0">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="SnapsToDevicePixels" Value="True" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="5"
                                            Height="28"
                                            Margin="3,1"
                                            Padding="8,0">
                                        <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="RevealButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chr" Background="Transparent" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chr" Property="Background" Value="#DDE1E6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushModern}" BorderThickness="0,0,0,1" Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="#101828" CornerRadius="10" Width="40" Height="40" Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Settings20" Foreground="#6CB6FF" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="16"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="Configure GitHub credentials, user secrets, and permissions"
                               Foreground="{DynamicResource MutedTextBrush}" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushModern}" BorderThickness="0,1,0,0" Padding="22,13">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Width="96"
                        Margin="0,0,10,0" Click="Cancel_Click" />
                <Button Style="{StaticResource PrimaryButton}" Width="96" Click="Save_Click">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save20" FontSize="15" Margin="0,0,6,0" />
                        <TextBlock Text="Save" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Margin="22,14">
            <TabControl>
                <!-- GitHub tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Key20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="GitHub" />
                        </StackPanel>
                    </TabItem.Header>
                    <Border Style="{StaticResource CardBorder}" Margin="0,14,0,0">
                        <StackPanel MaxWidth="520" HorizontalAlignment="Left">
                            <TextBlock Text="GitHub Authentication" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                            <TextBlock Text="Provide a personal access token to authenticate with GitHub Copilot."
                                       Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,0,0,16" />
                            <Separator Background="{DynamicResource BorderBrushModern}" Margin="0,0,0,16" />
                            <TextBlock Text="Personal Access Token" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <PasswordBox x:Name="GitHubTokenBox" Padding="9,0,36,0" />
                                <TextBox x:Name="GitHubTokenTextBox" Padding="9,0,36,0" Visibility="Collapsed" />
                                <Button x:Name="RevealGitHubTokenButton"
                                        Style="{StaticResource RevealButton}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,4,0" ToolTip="Show / hide token"
                                        Click="RevealGitHubTokenButton_Click">
                                    <ui:SymbolIcon x:Name="RevealGitHubTokenIcon" Symbol="Eye20" FontSize="14"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                </Button>
                            </Grid>
                            <TextBlock Text="Generate a token at github.com/settings/tokens with the 'copilot' scope."
                                       Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                       Margin="0,6,0,16" TextWrapping="Wrap" />
                            <TextBlock Text="Settings Password" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <PasswordBox x:Name="SettingsPasswordBox" Padding="9,0,36,0" />
                                <TextBox x:Name="SettingsPasswordTextBox" Padding="9,0,36,0" Visibility="Collapsed" />
                                <Button x:Name="RevealSettingsPasswordButton"
                                        Style="{StaticResource RevealButton}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,4,0" ToolTip="Show / hide settings password"
                                        Click="RevealSettingsPasswordButton_Click">
                                    <ui:SymbolIcon x:Name="RevealSettingsPasswordIcon" Symbol="Eye20" FontSize="14"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                </Button>
                            </Grid>
                            <TextBlock x:Name="SettingsPasswordHelpText"
                                       Text="Optional. When set, saved GitHub credentials and user secrets are encrypted with this password. The password is not saved."
                                       Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                       Margin="0,6,0,16" TextWrapping="Wrap" />
                            <Separator Background="{DynamicResource BorderBrushModern}" Margin="0,0,0,16" />
                            <TextBlock Text="Working Directory" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox x:Name="WorkingDirectoryBox" Grid.Column="0" PlaceholderText="Leave blank to use your home folder" />
                                <Button x:Name="BrowseWorkingDirButton" Grid.Column="1" Margin="6,0,0,0"
                                        Content="Browse…" Click="BrowseWorkingDir_Click" />
                            </Grid>
                            <TextBlock Text="The folder the Copilot CLI runs from. MCP servers configured in .github/copilot/mcp.json relative to this folder will be available."
                                       Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                       Margin="0,6,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Appearance tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="PaintBrush20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Appearance" />
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="660" HorizontalAlignment="Left">
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2" />
                                    <TextBlock Text="Controls when the light or dark colour scheme is applied."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                                               TextWrapping="Wrap" Margin="0,0,0,10" />
                                    <TextBlock Text="Colour Scheme" Style="{StaticResource FieldLabel}" />
                                    <ComboBox x:Name="ThemeComboBox" MaxWidth="260" HorizontalAlignment="Left" />
                                    <TextBlock Text="Follow the sun uses light mode 7 am – 7 pm and dark mode outside those hours."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Streaming" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2" />
                                    <TextBlock Text="Controls how response text is rendered while Copilot is writing."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                                               TextWrapping="Wrap" Margin="0,0,0,10" />
                                    <CheckBox x:Name="ResponseBufferingCheckBox"
                                              Content="Buffer streaming response updates"
                                              Margin="0,0,0,6"
                                              Checked="ResponseBufferingCheckBox_Changed"
                                              Unchecked="ResponseBufferingCheckBox_Changed" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="ResponseBufferIntervalSlider"
                                                Minimum="500"
                                                Maximum="2000"
                                                TickFrequency="100"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="ResponseBufferIntervalSlider_ValueChanged" />
                                        <TextBlock x:Name="ResponseBufferIntervalText"
                                                   Grid.Column="1"
                                                   Width="72"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="12" />
                                    </Grid>
                                    <TextBlock Text="Lower values feel live; higher values reduce flicker."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Notifications" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10" />
                                    <CheckBox x:Name="TrayNotificationsCheckBox"
                                              Content="Show tray notifications when Copilot needs a response"
                                              Margin="0,0,0,4" />
                                    <TextBlock Text="Shows a Windows tray balloon for permission requests, tool approvals, choices, and feedback prompts."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Session Defaults" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10" />
                                    <CheckBox x:Name="DefaultAutoCollapseCheckBox"
                                              Content="Collapse last response after user input is sent for new sessions"
                                              Margin="0,0,0,4" />
                                    <TextBlock Text="Existing sessions keep their own toolbar setting."
                                               Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- User Secrets tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="LockClosed20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="User Secrets" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="0,14,0,0">
                        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Column="1" Text="Environment Variable" Style="{StaticResource FieldLabel}" Margin="8,0,0,5" />
                                <TextBlock Grid.Column="2" Text="Value" Style="{StaticResource FieldLabel}" Margin="8,0,0,5" />
                                <TextBox x:Name="SecretNameBox" Grid.Row="1" Margin="0,0,8,0" />
                                <TextBox x:Name="SecretEnvBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,0" />
                                <PasswordBox x:Name="SecretValueBox" Grid.Row="1" Grid.Column="2" Margin="0,0,8,0" Padding="9,0,36,0" />
                                <TextBox x:Name="SecretValueTextBox" Grid.Row="1" Grid.Column="2" Margin="0,0,8,0"
                                         Padding="9,0,36,0" Visibility="Collapsed" />
                                <Button x:Name="RevealSecretButton" Grid.Row="1" Grid.Column="2"
                                        Style="{StaticResource RevealButton}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,12,0" ToolTip="Show / hide value"
                                        Click="RevealSecretButton_Click">
                                    <ui:SymbolIcon x:Name="RevealSecretIcon" Symbol="Eye20" FontSize="14"
                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                </Button>
                                <Button Content="Add" Grid.Row="1" Grid.Column="3" Style="{StaticResource SmallButton}"
                                        Width="60" Margin="0,0,6,0" Click="AddSecret_Click" />
                                <Button Content="Remove" Grid.Row="1" Grid.Column="4" Style="{StaticResource SmallButton}"
                                        Width="72" Click="RemoveSecret_Click" />
                            </Grid>
                        </Border>
                        <TextBox x:Name="SecretFilterBox"
                                 DockPanel.Dock="Top"
                                 Margin="0,0,0,10"
                                 TextChanged="SecretFilterBox_TextChanged"
                                 ToolTip="Filter user secrets" />
                        <Border Style="{StaticResource CardBorder}" Padding="0">
                            <DataGrid x:Name="SecretsGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                      SelectionChanged="SecretsGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Environment Variable" Binding="{Binding EnvironmentVariable}" Width="*" />
                                    <DataGridTemplateColumn Header="Value" Width="1.2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Margin="6,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="SecretGridValueText"
                                                               Text="********"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                    <Button x:Name="RevealSecretGridButton"
                                                            Grid.Column="1"
                                                            Style="{StaticResource RevealButton}"
                                                            ToolTip="Show / hide value"
                                                            Click="RevealSecretGridButton_Click">
                                                        <ui:SymbolIcon Symbol="Eye20" FontSize="14"
                                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="42">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource RevealButton}"
                                                        ToolTip="Remove secret"
                                                        Click="SecretDeleteButton_Click">
                                                    <ui:SymbolIcon Symbol="Delete20" FontSize="14"
                                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </DockPanel>
                </TabItem>

                <!-- Permissions tab (defaults + saved approvals) -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Shield20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Permissions" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="0,14,0,0">
                        <!-- Global defaults card -->
                        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Default Access" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,8" />
                                <CheckBox x:Name="AllowMcpCheckBox"
                                          Content="Allow MCP tools by default (no explicit approval needed)"
                                          Margin="0,0,0,6" />
                                <CheckBox x:Name="AllowCustomToolsCheckBox"
                                          Content="Allow custom tools by default (no explicit approval needed)" />
                            </StackPanel>
                        </Border>

                        <!-- Saved prompt approvals -->
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Saved Prompt Approvals" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{DynamicResource TextBrush}" />
                                <Button Content="Clear" Grid.Column="1" HorizontalAlignment="Right"
                                        Style="{StaticResource SmallButton}" Width="64" Margin="0,0,6,0"
                                        Click="ClearSavedRules_Click" />
                                <Button Content="Remove" Grid.Column="2" HorizontalAlignment="Right"
                                        Style="{StaticResource SmallButton}" Width="72"
                                        Click="RemoveSavedRule_Click" />
                            </Grid>
                            <TextBox x:Name="SavedRuleFilterBox"
                                     DockPanel.Dock="Top"
                                     Margin="0,0,0,8"
                                     TextChanged="SavedRuleFilterBox_TextChanged"
                                     ToolTip="Filter saved approvals" />
                            <Border Style="{StaticResource CardBorder}" Padding="0">
                                <DataGrid x:Name="SavedRulesGrid" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="90" />
                                        <DataGridTextColumn Header="Approval" Binding="{Binding Summary}" Width="*" />
                                        <DataGridTemplateColumn Width="42">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource RevealButton}"
                                                            ToolTip="Remove saved approval"
                                                            Click="SavedRuleDeleteButton_Click">
                                                        <ui:SymbolIcon Symbol="Delete20" FontSize="14"
                                                                       Foreground="{DynamicResource MutedTextBrush}" />
                                                    </Button>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </DockPanel>
                    </DockPanel>
                </TabItem>

                <!-- Folder Permissions tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Folder20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Folders" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="0,14,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="Folder Permissions" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" />
                        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="FolderPathBox" Margin="0,0,8,0" />
                                <CheckBox x:Name="FolderWriteBox" Content="Write" Grid.Column="1" Margin="0,0,8,0" />
                                <Button Content="Add" Grid.Column="2" Style="{StaticResource SmallButton}"
                                        Width="54" Margin="0,0,6,0" Click="AddFolder_Click" />
                                <Button Content="Remove" Grid.Column="3" Style="{StaticResource SmallButton}"
                                        Width="68" Click="RemoveFolder_Click" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Padding="0">
                            <DataGrid x:Name="FoldersGrid" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Folder" Binding="{Binding Path}" Width="*" />
                                    <DataGridTextColumn Header="Access" Binding="{Binding Access}" Width="80" />
                                    <DataGridTemplateColumn Header="" Width="42">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource RevealButton}"
                                                        ToolTip="Remove folder"
                                                        Click="FolderDeleteButton_Click">
                                                    <ui:SymbolIcon Symbol="Delete20"
                                                                   FontSize="14"
                                                                   Foreground="{DynamicResource MutedTextBrush}" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </DockPanel>
                </TabItem>

                <!-- Allowed Tools tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Wrench20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Tools" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="0,14,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="Allowed Tools" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" />
                        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ToolBox" Margin="0,0,8,0" />
                                <Button Content="Add" Grid.Column="1" Style="{StaticResource SmallButton}"
                                        Width="54" Margin="0,0,6,0" Click="AddTool_Click" />
                                <Button Content="Clear" Grid.Column="2" Style="{StaticResource SmallButton}"
                                        Width="64" Click="ClearTools_Click" />
                            </Grid>
                        </Border>
                        <TextBox x:Name="ToolFilterBox"
                                 DockPanel.Dock="Top"
                                 Margin="0,0,0,10"
                                 TextChanged="ToolFilterBox_TextChanged"
                                 ToolTip="Filter tools" />
                        <Border Style="{StaticResource CardBorder}" Padding="0">
                            <ListBox x:Name="ToolsList" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource RevealButton}"
                                                    ToolTip="Remove tool"
                                                    Click="ToolDeleteButton_Click">
                                                <ui:SymbolIcon Symbol="Delete20" FontSize="14"
                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </DockPanel>
                </TabItem>

                <!-- Allowed Hosts tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Globe20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Hosts" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="0,14,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="Allowed Hosts" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12" />
                        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="HostBox" Margin="0,0,8,0" />
                                <Button Content="Add" Grid.Column="1" Style="{StaticResource SmallButton}"
                                        Width="54" Margin="0,0,6,0" Click="AddHost_Click" />
                                <Button Content="Clear" Grid.Column="2" Style="{StaticResource SmallButton}"
                                        Width="64" Click="ClearHosts_Click" />
                            </Grid>
                        </Border>
                        <TextBox x:Name="HostFilterBox"
                                 DockPanel.Dock="Top"
                                 Margin="0,0,0,10"
                                 TextChanged="HostFilterBox_TextChanged"
                                 ToolTip="Filter hosts"
                                 />
                        <Border Style="{StaticResource CardBorder}" Padding="0">
                            <ListBox x:Name="HostsList" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource RevealButton}"
                                                    ToolTip="Remove host"
                                                    Click="HostDeleteButton_Click">
                                                <ui:SymbolIcon Symbol="Delete20" FontSize="14"
                                                               Foreground="{DynamicResource MutedTextBrush}" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </DockPanel>
                </TabItem>

                <!-- System Prompt tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ChatBubblesQuestion20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="System Prompt" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="0,14,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="Default System Prompt" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Applied automatically at the start of every new chat session. Leave blank to use no system prompt."
                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,12" />
                        <Border Style="{StaticResource CardBorder}" Padding="0">
                            <TextBox x:Name="SystemPromptBox"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="10,8" Height="Auto" MinHeight="120"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Top"
                                     FontSize="13" FontFamily="Consolas, Courier New, monospace"
                                     Foreground="{DynamicResource TextBrush}"
                                     Background="{DynamicResource SurfaceBrush}"
                                     VerticalAlignment="Stretch" />
                        </Border>
                    </DockPanel>
                </TabItem>

                <!-- Agents & Skills tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="PersonSettings20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Agents &amp; Skills" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="0,14,0,0">
                        <!-- Note banner -->
                        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,14">
                            <TextBlock Foreground="{DynamicResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}">Default locations loaded automatically: </Run>
                                <Run>~/.copilot/agents, &lt;working-dir&gt;/.github/agents, ~/.copilot/skills, &lt;working-dir&gt;/.github/skills</Run>
                                <LineBreak />
                                <Run>Add extra folders below. Changes take effect for new sessions.</Run>
                            </TextBlock>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Agents column -->
                            <DockPanel Grid.Column="0">
                                <TextBlock DockPanel.Dock="Top" Text="Extra Agent Folders" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8" />
                                <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AgentDirBox" Margin="0,0,6,0" />
                                        <Button Content="Browse…" Grid.Column="1" Style="{StaticResource SmallButton}"
                                                Margin="0,0,6,0" Click="BrowseAgentDir_Click" />
                                        <Button Content="Add" Grid.Column="2" Style="{StaticResource SmallButton}"
                                                Width="48" Click="AddAgentDir_Click" />
                                    </Grid>
                                </Border>
                                <DockPanel>
                                    <Button DockPanel.Dock="Top" Content="Remove selected"
                                            HorizontalAlignment="Right" Style="{StaticResource SmallButton}"
                                            Margin="0,0,0,6" Click="RemoveAgentDir_Click" />
                                    <Border Style="{StaticResource CardBorder}" Padding="0">
                                        <ListBox x:Name="AgentDirsList" BorderThickness="0" />
                                    </Border>
                                </DockPanel>
                            </DockPanel>

                            <!-- Skills column -->
                            <DockPanel Grid.Column="2">
                                <TextBlock DockPanel.Dock="Top" Text="Extra Skill Folders" FontWeight="SemiBold"
                                           FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8" />
                                <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SkillDirBox" Margin="0,0,6,0" />
                                        <Button Content="Browse…" Grid.Column="1" Style="{StaticResource SmallButton}"
                                                Margin="0,0,6,0" Click="BrowseSkillDir_Click" />
                                        <Button Content="Add" Grid.Column="2" Style="{StaticResource SmallButton}"
                                                Width="48" Click="AddSkillDir_Click" />
                                    </Grid>
                                </Border>
                                <DockPanel>
                                    <Button DockPanel.Dock="Top" Content="Remove selected"
                                            HorizontalAlignment="Right" Style="{StaticResource SmallButton}"
                                            Margin="0,0,0,6" Click="RemoveSkillDir_Click" />
                                    <Border Style="{StaticResource CardBorder}" Padding="0">
                                        <ListBox x:Name="SkillDirsList" BorderThickness="0" />
                                    </Border>
                                </DockPanel>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </TabItem>

                <!-- Debug tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Bug20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Debug" />
                        </StackPanel>
                    </TabItem.Header>
                    <DockPanel Margin="0,14,0,0">
                        <TextBlock DockPanel.Dock="Top" Text="Debug Logging" FontWeight="SemiBold"
                                   FontSize="14" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                        <TextBlock DockPanel.Dock="Top"
                                   Text="When enabled, all Copilot messages (user input, system messages, intent, reasoning, responses, tool calls, permission requests, and ask-user prompts) are written to a daily log file."
                                   Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,0,0,14" />

                        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                            <CheckBox x:Name="EnableDebugLoggingCheckBox"
                                      Content="Enable debug logging to file" />
                        </Border>

                        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorder}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Log file location"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,8" />
                                <Button DockPanel.Dock="Right"
                                        x:Name="OpenLogFolderButton"
                                        Content="Open folder"
                                        Style="{StaticResource SecondaryButton}"
                                        Width="110" Margin="10,0,0,0"
                                        Click="OpenLogFolder_Click" />
                                <TextBlock x:Name="LogPathTextBlock"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12" FontFamily="Consolas, Courier New, monospace"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
