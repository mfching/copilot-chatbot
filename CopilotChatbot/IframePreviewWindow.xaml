<Window x:Class="CopilotChatbot.IframePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Preview"
        Height="760"
        Width="980"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ControlBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="BorderBrushModern" Color="#D0D7DE" />
        <SolidColorBrush x:Key="TextBrush" Color="#1F2328" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5D6673" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0A65CC" />
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushModern}"
                BorderThickness="0,0,0,1"
                Padding="16,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource ControlBrush}"
                            BorderBrush="{DynamicResource BorderBrushModern}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Width="32"
                            Height="32"
                            Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="Open20"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Live Preview"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextBrush}" />
                                   FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Click="Save_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Chr"
                                    Background="{DynamicResource AccentBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Margin="12,7">
                                    <ui:SymbolIcon Symbol="Save20" FontSize="15" Foreground="White" Margin="0,0,6,0" />
                                    <TextBlock Text="Save" FontWeight="SemiBold" FontSize="13" Foreground="White" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chr" Property="Background" Value="#0856B3" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        <wv2:WebView2 x:Name="Browser" />
    </DockPanel>
</Window>
