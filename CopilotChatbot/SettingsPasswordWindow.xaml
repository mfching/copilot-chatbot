<Window x:Class="CopilotChatbot.SettingsPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Settings Password"
        SizeToContent="Height"
        MinHeight="292"
        Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource PageBrush}">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="PrimaryDialogButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style x:Key="RevealButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushModern}"
            BorderThickness="1"
            CornerRadius="8"
            Margin="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border BorderBrush="{DynamicResource BorderBrushModern}"
                    BorderThickness="0,0,0,1"
                    Padding="18,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="#101828" CornerRadius="8" Width="36" Height="36" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="LockClosed20"
                                       Foreground="#6CB6FF"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Unlock Settings"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="Decrypt saved GitHub credentials and user secrets"
                                   FontSize="12"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="18,16,18,18">
                <TextBlock Text="Settings Password"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,6" />
                <Grid>
                    <PasswordBox x:Name="PasswordBox"
                                 Height="36"
                                 Padding="10,0,38,0"
                                 Background="{DynamicResource ControlBrush}"
                                 BorderBrush="{DynamicResource BorderBrushModern}"
                                 BorderThickness="1"
                                 Foreground="{DynamicResource TextBrush}"
                                 VerticalContentAlignment="Center" />
                    <TextBox x:Name="PasswordTextBox"
                             Height="36"
                             Padding="10,0,38,0"
                             Background="{DynamicResource ControlBrush}"
                             BorderBrush="{DynamicResource BorderBrushModern}"
                             BorderThickness="1"
                             Foreground="{DynamicResource TextBrush}"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed" />
                    <Button Style="{StaticResource RevealButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,5,0"
                            ToolTip="Show / hide password"
                            Click="RevealPassword_Click">
                        <ui:SymbolIcon x:Name="RevealPasswordIcon"
                                       Symbol="Eye20"
                                       FontSize="14"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                    </Button>
                </Grid>
                <TextBlock Text="This password is used only for this session and is not saved."
                           FontSize="11"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="0,7,0,0" />
            </StackPanel>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource BorderBrushModern}"
                    BorderThickness="0,1,0,0"
                    Padding="18,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Style="{StaticResource DialogButton}"
                            Margin="0,0,8,0"
                            IsCancel="True" />
                    <Button Style="{StaticResource PrimaryDialogButton}"
                            IsDefault="True"
                            Click="Unlock_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Key20" FontSize="14" Margin="0,0,6,0" />
                            <TextBlock Text="Unlock" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
