<Window x:Class="CopilotChatbot.SchedulerHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task run history" Height="640" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PageBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="HeaderText" FontSize="16" FontWeight="SemiBold" />
            <Button Content="Refresh" Style="{StaticResource Btn}" Click="Refresh_Click" Margin="14,0,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid>
                <ListBox x:Name="RunsList"
                         Background="{DynamicResource ControlBrush}"
                         BorderBrush="{DynamicResource BorderBrushModern}"
                         Foreground="{DynamicResource TextBrush}"
                         SelectionChanged="RunsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding StartedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                    <TextBlock Text=" — " />
                                    <TextBlock Text="{Binding Status}" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="{Binding Trigger}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="NoRunsPlaceholder"
                           Text="No run history yet. Use 'Run Now' to execute the task."
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="16"
                           IsHitTestVisible="False" Visibility="Collapsed" />
            </Grid>
            <TextBox x:Name="DetailBox" Grid.Column="1" Margin="8,0,0,0"
                     IsReadOnly="True" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     Background="{DynamicResource ControlBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrushModern}" />
        </Grid>

        <Button Grid.Row="2" Content="Close" Style="{StaticResource Btn}"
                HorizontalAlignment="Right" Margin="0,10,0,0" Click="Close_Click" />
    </Grid>
</Window>
